// Secrets.swift.example — commit this file, not Secrets.swift
// To set up: copy this file to Secrets.swift and fill in your API key.
//
//   cp iOS/FastWeather/Services/Secrets.swift.example \
//      iOS/FastWeather/Services/Secrets.swift
//
// Get an Open-Meteo API key at https://open-meteo.com/en/pricing
// Set nil to use the free tier (rate-limited, no dedicated servers).

enum Secrets {
    static let openMeteoAPIKey: String? = nil   // replace with your key
}
