    "**Add to My City List** — permanently saves your current location as a city" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**Zu meiner Städteliste hinzufügen** – speichert Ihren aktuellen Standort dauerhaft als Stadt"
          }
        },
        "es" : {
          "stringUnit" : {
