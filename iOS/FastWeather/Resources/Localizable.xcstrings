    "To use your current location, please enable location access in Settings > Privacy > Location Services." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Um deinen aktuellen Standort zu nutzen, aktiviere bitte den Standortzugriff unter Einstellungen > Datenschutz > Ortungsdienste."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Para usar tu ubicación actual, activa el acceso a la ubicación en Ajustes > Privacidad > Localización."
