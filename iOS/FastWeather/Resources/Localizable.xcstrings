          }
        }
      }
    },
    "**\"Approaching at X mph\"** - Weather is moving toward your location" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"Nähert sich mit X mph\"** – Das Wetter zieht auf Ihren Standort zu"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"Acercándose a X mph\"** - El tiempo se mueve hacia tu ubicación"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"In avvicinamento a X mph\"** - Il tempo si sta muovendo verso la tua posizione"
          }
        }
      }
    },
    "**\"Moving away at X mph\"** - Weather is moving away from you" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"Entfernt sich mit X mph\"** – Das Wetter zieht von Ihnen weg"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"Alejándose a X mph\"** - El tiempo se aleja de ti"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"In allontanamento a X mph\"** - Il tempo si sta allontanando da te"
          }
        }
      }
    },
    "**\"Moving parallel at X mph\"** - Weather is moving perpendicular to your direction" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"Bewegt sich parallel mit X mph\"** – Das Wetter bewegt sich quer zu Ihrer Richtung"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"Movimiento paralelo a X mph\"** - El tiempo se mueve perpendicular a tu dirección"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"In movimento parallelo a X mph\"** - Il tempo si sta muovendo perpendicolarmente alla tua direzione"
          }
        }
      }
    },
    "**\"On center line\"** - City is directly along your chosen direction" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"Auf der Mittellinie\"** – Die Stadt liegt direkt in Ihrer gewählten Richtung"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"En la línea central\"** - La ciudad está justo en la dirección que elegiste"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"Sulla linea centrale\"** - La città si trova esattamente lungo la direzione scelta"
          }
        }
      }
    },
    "**\"Winds X mph\"** - Current wind speed when movement is minimal" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"Wind X mph\"** – Aktuelle Windgeschwindigkeit, wenn kaum Bewegung vorliegt"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"Vientos de X mph\"** - Velocidad actual del viento cuando el movimiento es mínimo"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**\"Vento X mph\"** - Velocità attuale del vento quando il movimento è minimo"
          }
        }
      }
    },
