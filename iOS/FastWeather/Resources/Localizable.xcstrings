    "Tap 'Load History' to view" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tippe auf „Verlauf laden“, um anzuzeigen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Toca 'Cargar historial' para ver"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tocca 'Carica cronologia' per visualizzare"
          }
        }
      }
    },
    "Tap **Add Widget**, then drag it to the position you want" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tippe auf **Widget hinzufügen** und ziehe es dann an die gewünschte Position"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Toca **Añadir widget** y luego arrástralo a la posición que quieras"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tocca **Aggiungi widget**, quindi trascinalo nella posizione desiderata"
          }
        }
      }
    },
    "Tap any direction to explore cities along that path. For example, tap \"North\" to see all cities north of your location." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tippe auf eine beliebige Richtung, um Städte entlang dieses Wegs zu erkunden. Tippe zum Beispiel auf „Norden“, um alle Städte nördlich deines Standorts zu sehen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Toca cualquier dirección para explorar las ciudades a lo largo de ese trayecto. Por ejemplo, toca \"Norte\" para ver todas las ciudades al norte de tu ubicación."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tocca una direzione qualsiasi per esplorare le città lungo quel percorso. Ad esempio, tocca \"Nord\" per vedere tutte le città a nord della tua posizione."
          }
        }
      }
    },
    "Tap the **+** button in the top-left corner to open the widget gallery" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tippe auf die Schaltfläche **+** oben links, um die Widget-Galerie zu öffnen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Toca el botón **+** de la esquina superior izquierda para abrir la galería de widgets"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tocca il pulsante **+** nell'angolo in alto a sinistra per aprire la galleria dei widget"
          }
        }
      }
    },
    "Tap the **City** row to open the picker" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tippe auf die Zeile **Stadt**, um die Auswahl zu öffnen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Toca la fila **Ciudad** para abrir el selector"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tocca la riga **Città** per aprire il selettore"
          }
        }
      }
    },
    "Tap the lock screen face, then tap a widget slot" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tippe auf das Sperrbildschirm-Ziffernblatt und dann auf einen Widget-Platz"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Toca la pantalla de bloqueo y luego toca una ranura de widget"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tocca il quadrante della schermata di blocco, quindi tocca uno spazio per widget"
          }
        }
      }
    },
    "Tap to delete cached historical data for all cities" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tippen, um zwischengespeicherte Verlaufsdaten für alle Städte zu löschen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Toca para eliminar los datos históricos en caché de todas las ciudades"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tocca per eliminare i dati storici memorizzati nella cache per tutte le città"
          }
        }
      }
    },
    "Tap to enable reordering of weather fields" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tippen, um das Neuanordnen von Wetterfeldern zu aktivieren"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Toca para activar la reordenación de los campos meteorológicos"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tocca per abilitare il riordino dei campi meteo"
          }
        }
      }
    },
    "Tap to navigate to %@ %lld" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tippen, um zu %1$@ %2$lld zu navigieren"
