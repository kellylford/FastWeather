    "Toggle which sections appear in the current weather detail view. Use VoiceOver actions to reorder sections." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Lege fest, welche Bereiche in der aktuellen Wetterdetailansicht erscheinen. Verwende VoiceOver-Aktionen, um die Bereiche neu anzuordnen."
          }
        },
        "es" : {
          "stringUnit" : {
