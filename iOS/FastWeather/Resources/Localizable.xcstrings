    "WeatherKit nowcast is disabled. Expected Precipitation uses Open-Meteo NWP for all cities, restoring the older experience." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Der WeatherKit-Nowcast ist deaktiviert. „Erwarteter Niederschlag“ verwendet Open-Meteo NWP für alle Städte und stellt das ältere Erlebnis wieder her."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "El pronóstico inmediato de WeatherKit está desactivado. La Precipitación prevista usa el modelo NWP de Open-Meteo para todas las ciudades, restaurando la experiencia anterior."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Il nowcast di WeatherKit è disabilitato. Precipitazioni previste usa il modello NWP di Open-Meteo per tutte le città, ripristinando l'esperienza precedente."
          }
        }
      }
    },
    "WeatherKit nowcast is enabled. Expected Precipitation uses radar-quality minute-by-minute data from Apple WeatherKit for supported countries." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Der WeatherKit-Nowcast ist aktiviert. „Erwarteter Niederschlag“ verwendet für unterstützte Länder minutengenaue Daten in Radarqualität von Apple WeatherKit."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "El pronóstico inmediato de WeatherKit está activado. La Precipitación prevista usa datos minuto a minuto de calidad radar de Apple WeatherKit para los países compatibles."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Il nowcast di WeatherKit è abilitato. Precipitazioni previste usa dati minuto per minuto di qualità radar da Apple WeatherKit per i paesi supportati."
          }
        }
      }
    },
    "WeatherKit snow is disabled. Daily snow totals use Open-Meteo. Enable to test WeatherKit accuracy on lake-effect snow events." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "WeatherKit-Schnee ist deaktiviert. Tägliche Schneesummen verwenden Open-Meteo. Aktiviere die Option, um die WeatherKit-Genauigkeit bei Lake-Effect-Schneeereignissen zu testen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La nieve de WeatherKit está desactivada. Los totales diarios de nieve usan Open-Meteo. Actívala para probar la precisión de WeatherKit en eventos de nieve por efecto lago."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La neve di WeatherKit è disabilitata. I totali giornalieri di neve usano Open-Meteo. Abilita per testare l'accuratezza di WeatherKit sugli eventi di neve da effetto lago."
          }
        }
      }
    },
    "WeatherKit snow is enabled. Daily snow totals come from Apple WeatherKit instead of Open-Meteo." : {
