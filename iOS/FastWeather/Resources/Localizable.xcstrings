    "Welcome to Weather Fast" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Willkommen bei Weather Fast"
          }
        },
        "es" : {
          "stringUnit" : {
