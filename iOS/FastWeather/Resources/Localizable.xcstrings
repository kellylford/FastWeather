    "WeatherKit alerts work in: Canada, UK, Germany, France, Spain, Italy, Japan, Australia, and other select countries. Russia, many Asian countries, and Africa have limited/no coverage." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "WeatherKit-Warnungen funktionieren in: Kanada, Großbritannien, Deutschland, Frankreich, Spanien, Italien, Japan, Australien und anderen ausgewählten Ländern. Russland, viele asiatische Länder und Afrika haben eine eingeschränkte oder keine Abdeckung."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Los avisos de WeatherKit funcionan en: Canadá, Reino Unido, Alemania, Francia, España, Italia, Japón, Australia y otros países seleccionados. Rusia, muchos países de Asia y África tienen cobertura limitada o nula."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Gli avvisi di WeatherKit funzionano in: Canada, Regno Unito, Germania, Francia, Spagna, Italia, Giappone, Australia e altri paesi selezionati. Russia, molti paesi asiatici e Africa hanno copertura limitata o nulla."
          }
        }
      }
    },
