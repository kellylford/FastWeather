    "\"Milwaukee, Wisconsin, 80 miles, 5 degrees, 3 miles east of center line, 72°F, Overcast, Alert: Tornado Warning, Approaching at 15 mph, Pressure steady, 2 of 15\"" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "\"Milwaukee, Wisconsin, 80 Meilen, 5 Grad, 3 Meilen östlich der Mittellinie, 72°F, Bedeckt, Warnung: Tornado-Warnung, Nähert sich mit 15 mph, Luftdruck stabil, 2 von 15\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "\"Milwaukee, Wisconsin, 80 millas, 5 grados, 3 millas al este de la línea central, 72°F, Nublado, Alerta: Aviso de tornado, Acercándose a 15 mph, Presión estable, 2 de 15\""
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "\"Milwaukee, Wisconsin, 80 miglia, 5 gradi, 3 miglia a est della linea centrale, 72°F, Coperto, Allerta: Allerta tornado, In avvicinamento a 15 mph, Pressione stabile, 2 di 15\""
          }
        }
      }
    },
    "\"Oregon, Wisconsin, 10 miles, 180 degrees, On center line, 65°F, Clear, Winds 3 mph, 1 of 8\"" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "\"Oregon, Wisconsin, 10 Meilen, 180 Grad, Auf der Mittellinie, 65°F, Klar, Wind 3 mph, 1 von 8\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "\"Oregon, Wisconsin, 10 millas, 180 grados, En la línea central, 65°F, Despejado, Vientos de 3 mph, 1 de 8\""
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "\"Oregon, Wisconsin, 10 miglia, 180 gradi, Sulla linea centrale, 65°F, Sereno, Vento 3 mph, 1 di 8\""
          }
        }
      }
    },
    "* Limited Coverage" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "* Eingeschränkte Abdeckung"
