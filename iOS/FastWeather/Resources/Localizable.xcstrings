    "Section appears when enabled in Settings → Detail Categories" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Der Bereich erscheint, wenn er unter Einstellungen → Detailkategorien aktiviert ist"
          }
        },
