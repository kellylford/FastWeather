    "**Alternative:** Use the **left and right arrow buttons** in the toolbar to navigate between days" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**Alternative:** Nutzen Sie die **Pfeiltasten links und rechts** in der Symbolleiste, um zwischen den Tagen zu wechseln"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**Alternativa:** Usa los **botones de flecha izquierda y derecha** en la barra de herramientas para navegar entre días"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "**Alternativa:** usa i **pulsanti freccia sinistra e destra** nella barra degli strumenti per spostarti tra i giorni"
          }
        }
      }
    },
