    },
    "You will never lose a city list without explicitly choosing to." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Du verlierst niemals eine Städteliste, ohne dich ausdrücklich dafür zu entscheiden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Nunca perderás una lista de ciudades sin elegirlo explícitamente."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Non perderai mai un elenco di città senza sceglierlo esplicitamente."
          }
        }
      }
    },
    "Your accessible, feature-rich weather companion" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Dein zugänglicher, funktionsreicher Wetterbegleiter"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tu compañera meteorológica accesible y llena de funciones"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Il tuo compagno meteo accessibile e ricco di funzioni"
          }
        }
      }
    },
    "Your current position is reverse-geocoded to a specific place name — including neighborhood when available (e.g., \"Midtown, New York\" instead of just \"New York\")" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Deine aktuelle Position wird per Reverse-Geocoding einem bestimmten Ortsnamen zugeordnet – einschließlich Stadtviertel, sofern verfügbar (z. B. „Midtown, New York“ statt nur „New York“)"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tu posición actual se geocodifica de forma inversa a un nombre de lugar específico, incluyendo el barrio cuando está disponible (p. ej., \"Midtown, Nueva York\" en lugar de solo \"Nueva York\")"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La tua posizione attuale viene geocodificata in modo inverso in un nome di luogo specifico — incluso il quartiere quando disponibile (ad es. \"Midtown, New York\" invece del semplice \"New York\")"
          }
        }
      }
    },
    "Your Location" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Dein Standort"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tu ubicación"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La tua posizione"
          }
        }
      }
    },
    "Your location data is always device-specific and never syncs to your other devices. If you have an iPhone in New York and an iPad in Chicago, each shows weather for where it actually is. Your iPhone will not send its New York position to your iPad." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Deine Standortdaten sind immer gerätespezifisch und werden niemals mit deinen anderen Geräten synchronisiert. Wenn du ein iPhone in New York und ein iPad in Chicago hast, zeigt jedes Gerät das Wetter für seinen tatsächlichen Standort an. Dein iPhone sendet seine New-York-Position nicht an dein iPad."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tus datos de ubicación son siempre específicos de cada dispositivo y nunca se sincronizan con tus demás dispositivos. Si tienes un iPhone en Nueva York y un iPad en Chicago, cada uno muestra el tiempo del lugar donde realmente está. Tu iPhone no enviará su posición de Nueva York a tu iPad."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "I dati sulla tua posizione sono sempre specifici per ciascun dispositivo e non si sincronizzano mai con gli altri dispositivi. Se hai un iPhone a New York e un iPad a Chicago, ognuno mostra il meteo del luogo in cui si trova effettivamente. Il tuo iPhone non invierà la sua posizione di New York al tuo iPad."
          }
        }
      }
    }
  },
  "version" : "1.0"
