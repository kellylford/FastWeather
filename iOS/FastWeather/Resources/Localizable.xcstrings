    "Access settings two ways: tap the gear icon in Weather Around Me, or go to Settings → Weather Around Me." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sie erreichen die Einstellungen auf zwei Wegen: Tippen Sie auf das Zahnradsymbol in Wetter um mich herum, oder gehen Sie zu Einstellungen → Wetter um mich herum."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Accede a los ajustes de dos formas: toca el icono de engranaje en El tiempo a mi alrededor, o ve a Ajustes → El tiempo a mi alrededor."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Accedi alle impostazioni in due modi: tocca l'icona dell'ingranaggio in Meteo intorno a me, oppure vai su Impostazioni → Meteo intorno a me."
          }
        }
      }
    },
