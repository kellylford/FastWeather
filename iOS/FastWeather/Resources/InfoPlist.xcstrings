    "NSLocationUsageDescription": {
      "comment": "Shown in the system location-permission dialog. Explains why the app may add the user's current city automatically.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Weather Fast can use your location to automatically add your current city to the weather list."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Weather Fast può usare la tua posizione per aggiungere automaticamente la tua città attuale all'elenco meteo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Weather Fast puede usar tu ubicación para añadir automáticamente tu ciudad actual a la lista del tiempo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Weather Fast kann deinen Standort verwenden, um deine aktuelle Stadt automatisch zur Wetterliste hinzuzufügen."
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription": {
      "comment": "Shown in the system location-permission dialog the first time the app asks for location.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Weather Fast uses your location to show weather for your current area."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Weather Fast usa la tua posizione per mostrare il meteo della tua zona attuale."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Weather Fast usa tu ubicación para mostrar el tiempo de tu zona actual."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Weather Fast verwendet deinen Standort, um das Wetter für deine aktuelle Umgebung anzuzeigen."
          }
        }
      }
    }
  },
  "version": "1.0"
