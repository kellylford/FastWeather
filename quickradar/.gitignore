# QuickRadar experiment data (generated outputs)
# These are reproducible by running the scripts — no need to version-control
# the raw radar images and report files.
data/

# weather_lab.py per-run output (images, audio, report.html — all regenerable)
runs/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Test images from development
test_*.gif
test_*.png
# Radar experiment output snapshots (regenerable via quickradar.py)
radar_*.gif
radar_*.png

# Per-run output files (text dumps, summaries, comparisons)
weather_*.txt
experiment_summary_*.txt
model_comparison_*.txt
